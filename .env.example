# ===========================================
# Funil OS - Environment Variables Template
# ===========================================
# Copy this file to .env and fill in values
# NEVER commit .env to git

# --- App ---
VITE_APP_NAME=Funil OS
VITE_APP_VERSION=0.0.5
VITE_APP_ENV=development

# --- API ---
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=30000

# --- Auth (Supabase / Firebase) ---
VITE_AUTH_PROVIDER=none
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Feature Flags ---
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CANVAS_AUTOSAVE=true
VITE_ENABLE_COLLABORATION=false

# --- Storage ---
VITE_STORAGE_PREFIX=funilos_v1_
VITE_STORAGE_VERSION=1
